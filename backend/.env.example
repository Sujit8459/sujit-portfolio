# Copy this file to .env for local development.
# On Render, set these as Environment Variables in the dashboard instead.

# Your Gmail address (this is where contact form messages will be sent AND from)
EMAIL_USER=your.email@gmail.com

# A Gmail App Password (NOT your normal Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google account)
EMAIL_PASS=your-16-character-app-password

# Port the server listens on locally (Render sets this automatically in production)
PORT=4000

# Your deployed Vercel frontend URL, e.g. https://sujit-portfolio.vercel.app
# Use * only for local testing, never in production
ALLOWED_ORIGIN=*
